# Skills Passport environment variables
#
# In production (Vercel), these are provided automatically when you
# connect a Vercel KV (Upstash Redis) store to the project. Copy this
# file to `.env.local` only if you want to point local dev at a real KV.
#
# If these are NOT set, the app automatically falls back to a local
# JSON file store (.passport-store.json) so you can develop with no
# external services. See lib/kv.ts.

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional. The public origin used when generating passport one-liners.
# Falls back to the request's own origin, then to https://skillspassport.io
NEXT_PUBLIC_BASE_URL=
